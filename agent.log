{"type":"done","result":{"type":"tool_call","subtype":"completed","call_id":"tool_ea598d13-3858-4d28-a073-87d02198b4b","tool_call":{"readToolCall":{"args":{"path":"/home/zanbook/Projects/Alpha/LLM/Agent Coder/tasks/workspaces/5/frontend/src/features/tasks/statusLabels.js"},"result":{"success":{"content":"export const STATUS_LABELS = {\n  open: 'Aberta',\n  queued: 'Na fila',\n  in_progress: 'Em progresso',\n  done: 'Concluída',\n  rejected: 'Rejeitada',\n};\n\n/** Ordem das colunas no board Kanban (fluxo do pipeline). */\nexport const STATUS_ORDER = ['open', 'queued', 'in_progress', 'done', 'rejected'];\n\nexport function getStatusLabel(status) {\n  return STATUS_LABELS[status] ?? status;\n}\n\n/**\n * Agrupa tarefas por status para as colunas do Kanban.\n * @param {Array<{ id: number, status: string, [key: string]: unknown }>} tasks\n * @returns {Record<string, typeof tasks>}\n */\nexport function groupTasksByStatus(tasks) {\n  const groups = { open: [], queued: [], in_progress: [], done: [], rejected: [] };\n  if (!tasks?.length) return groups;\n  for (const task of tasks) {\n    const status = task.status in groups ? task.status : 'open';\n    groups[status].push(task);\n  }\n  return groups;\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":30,"fileSize":885,"path":"/home/zanbook/Projects/Alpha/LLM/Agent Coder/tasks/workspaces/5/frontend/src/features/tasks/statusLabels.js","readRange":{"startLine":1,"endLine":30},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}}},"model_call_id":"9440baa9-7fa5-47b2-a554-e95beb8ada51-2-y2mz","session_id":"0faf036e-d1fe-4c0d-a3ca-d0b55c32e62e","timestamp_ms":1772923231585},"at":"2026-03-07T22:40:31.586Z"}
