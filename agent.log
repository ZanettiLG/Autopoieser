{"type":"done","result":{"type":"tool_call","subtype":"completed","call_id":"tool_738d7d90-5d05-41e3-ad70-9523906de3b","tool_call":{"readToolCall":{"args":{"path":"/home/zanbook/Projects/Alpha/LLM/Agent Coder/tasks/workspaces/5/frontend/src/features/tasks/statusLabels.js"},"result":{"success":{"content":"export const STATUS_LABELS = {\n  open: 'Aberta',\n  queued: 'Na fila',\n  in_progress: 'Em progresso',\n  done: 'Concluída',\n  rejected: 'Rejeitada',\n};\n\n/** Ordem das colunas no board Kanban (fluxo do pipeline). */\nexport const STATUS_ORDER = ['open', 'queued', 'in_progress', 'done', 'rejected'];\n\nexport function getStatusLabel(status) {\n  return STATUS_LABELS[status] ?? status;\n}\n\n/**\n * Agrupa tarefas por status para as colunas do Kanban.\n * @param {Array<{ id: number, status: string, [key: string]: unknown }>} tasks\n * @returns {Record<string, typeof tasks>}\n */\nexport function groupTasksByStatus(tasks) {\n  const groups = { open: [], queued: [], in_progress: [], done: [], rejected: [] };\n  if (!tasks?.length) return groups;\n  for (const task of tasks) {\n    const status = task.status in groups ? task.status : 'open';\n    groups[status].push(task);\n  }\n  return groups;\n}\n","isEmpty":false,"exceededLimit":false,"totalLines":30,"fileSize":885,"path":"/home/zanbook/Projects/Alpha/LLM/Agent Coder/tasks/workspaces/5/frontend/src/features/tasks/statusLabels.js","readRange":{"startLine":1,"endLine":30},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}}},"model_call_id":"88f00ed5-7ed8-4481-a047-0c1de186f520-2-yjm3","session_id":"c9032feb-bd3f-40ea-9a01-95bdb9c0c2f1","timestamp_ms":1772920509938},"at":"2026-03-07T21:55:09.939Z"}
