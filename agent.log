,\n      }),\n      invalidatesTags: (_result, _err, id) => [\n        { type: 'Task', id },\n        { type: 'TaskList', id: 'LIST' },\n      ],\n    }),\n    queueTask: builder.mutation({\n      query: (id) => ({\n        url: `/api/tasks/${id}/queue`,\n        method: 'POST',\n      }),\n      invalidatesTags: (_result, _err, id) => [\n        { type: 'Task', id },\n        { type: 'TaskList', id: 'LIST' },\n      ],\n    }),\n    addComment: builder.mutation({\n      query: ({ taskId, content }) => ({\n        url: `/api/tasks/${taskId}/comments`,\n        method: 'POST',\n        body: { content, author: 'user' },\n      }),\n      invalidatesTags: (_result, _err, { taskId }) => [\n        { type: 'TaskComments', id: taskId },\n        { type: 'Task', id: taskId },\n      ],\n    }),\n  }),\n});\n\nexport const {\n  useGetTasksQuery,\n  useGetTaskQuery,\n  useGetTaskLogQuery,\n  useGetTaskCommentsQuery,\n  useCreateTaskMutation,\n  useUpdateTaskMutation,\n  useDeleteTaskMutation,\n  useQueueTaskMutation,\n  useAddCommentMutation,\n} = tasksApi;\n","isEmpty":false,"exceededLimit":false,"totalLines":94,"fileSize":2679,"path":"/home/zanbook/Projects/Alpha/LLM/Agent Coder/tasks/workspaces/5/frontend/src/app/api/tasksApi.js","readRange":{"startLine":1,"endLine":94},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}}},"model_call_id":"78ed6c20-9705-4284-9d61-44b262e21487-2-zje5","session_id":"da9662be-9026-4f16-bcc0-aabb8b654ae7","timestamp_ms":1772921328336},"at":"2026-03-07T22:08:48.337Z"}
