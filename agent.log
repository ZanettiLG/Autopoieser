,\n      }),\n      invalidatesTags: (_result, _err, id) => [\n        { type: 'Task', id },\n        { type: 'TaskList', id: 'LIST' },\n      ],\n    }),\n    queueTask: builder.mutation({\n      query: (id) => ({\n        url: `/api/tasks/${id}/queue`,\n        method: 'POST',\n      }),\n      invalidatesTags: (_result, _err, id) => [\n        { type: 'Task', id },\n        { type: 'TaskList', id: 'LIST' },\n      ],\n    }),\n    addComment: builder.mutation({\n      query: ({ taskId, content }) => ({\n        url: `/api/tasks/${taskId}/comments`,\n        method: 'POST',\n        body: { content, author: 'user' },\n      }),\n      invalidatesTags: (_result, _err, { taskId }) => [\n        { type: 'TaskComments', id: taskId },\n        { type: 'Task', id: taskId },\n      ],\n    }),\n  }),\n});\n\nexport const {\n  useGetTasksQuery,\n  useGetTaskQuery,\n  useGetTaskLogQuery,\n  useGetTaskCommentsQuery,\n  useCreateTaskMutation,\n  useUpdateTaskMutation,\n  useDeleteTaskMutation,\n  useQueueTaskMutation,\n  useAddCommentMutation,\n} = tasksApi;\n","isEmpty":false,"exceededLimit":false,"totalLines":94,"fileSize":2679,"path":"/home/zanbook/Projects/Alpha/LLM/Agent Coder/tasks/workspaces/5/frontend/src/app/api/tasksApi.js","readRange":{"startLine":1,"endLine":94},"relatedCursorRulePaths":[],"relatedCursorRules":[]}}}},"model_call_id":"9440baa9-7fa5-47b2-a554-e95beb8ada51-4-ztdh","session_id":"0faf036e-d1fe-4c0d-a3ca-d0b55c32e62e","timestamp_ms":1772923241717},"at":"2026-03-07T22:40:41.717Z"}
