{
  "name": "agent-coder",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,frontend \"npm run dev:server\" \"npm run dev:frontend\"",
    "dev:server": "cd backend && npm run server",
    "dev:frontend": "cd frontend && npm run dev",
    "start": "concurrently -n server,worker \"npm run start:server\" \"npm run start:worker\"",
    "start:server": "cd backend && npm run server",
    "start:worker": "cd backend && npm run worker",
    "test": "concurrently -n backend,frontend \"npm run test:backend\" \"npm run test:frontend\"",
    "test:backend": "cd backend && npm test",
    "test:frontend": "cd frontend && npm run test",
    "test:coverage": "cd frontend && npm run test:coverage",
    "build:frontend": "cd frontend && npm run build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
